# ClearBorder — Configuration
# Copier vers .env et adapter

# PostgreSQL (prod / docker)
# DATABASE_URL=postgresql://clearborder:clearborder@localhost:5432/clearborder
# SQLite pour dev rapide (par défaut)
DATABASE_URL=sqlite:///./clearborder.db

API_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
# Clés API (optionnel). Vide = pas d'auth. En prod: API_KEYS=sk-xxx,sk-yyy
# API_KEYS=sk-prod-xxx,sk-prod-yyy

# TARIC/EU (optionnel, pour sync données)
# TARIC_API_URL=https://ec.europa.eu/taxation_customs/dds2/rd/rd_home.jsp
